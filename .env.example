# Supabase (Project Settings → Data API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY

# Supabase service role key (Project Settings → Data API)
# Keep this server-side only; never expose in client code.
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_MONTHLY_ID=price_xxx
STRIPE_PRICE_YEARLY_ID=price_xxx

# Email provider
RESEND_API_KEY=re_xxx

# Admin access control (comma-separated emails)
ADMIN_EMAILS=admin@golfgives.co.uk

